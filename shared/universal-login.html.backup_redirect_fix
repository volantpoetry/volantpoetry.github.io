<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>Sign In · Volant Foundry</title>
  <!-- Google Font & Font Awesome -->
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<!-- Favicons -->
<link rel="icon" type="image/png" href="../images/volant-foundry-favicon.png">
<link rel="apple-touch-icon" href="../images/volant-foundry-favicon.png">

 <style>
    /* ----- reset & base ----- */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: linear-gradient(145deg, #f6f4fc 0%, #edebf5 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      margin: 0;
    }

    /* ----- card container (glassmorphism) ----- */
    .container {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-radius: 40px;
      padding: 2.5rem 2.2rem;
      max-width: 480px;
      width: 100%;
      box-shadow: 
        0 30px 60px -20px rgba(0,0,0,0.25),
        0 8px 24px rgba(0,0,0,0.04),
        inset 0 1px 0 rgba(255,255,255,0.6);
      border: 1px solid rgba(255,255,255,0.3);
      transition: all 0.2s ease;
    }

    /* ----- hide breadcrumb & back link completely ----- */
    .back-link,
    .breadcrumb {
      display: none !important;
    }

    /* ----- platform badge (dynamic) ----- */
    .platform-badge {
      display: inline-block;
      padding: 0.45rem 1.2rem;
      border-radius: 60px;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.3px;
      text-transform: uppercase;
      background: #4b2aad;
      color: white;
      margin-bottom: 1.2rem;
      box-shadow: 0 4px 8px rgba(75, 42, 173, 0.15);
      transition: 0.2s;
    }
    .platform-badge.poetry { background: linear-gradient(135deg, #4b2aad, #7a4fdb); }
    .platform-badge.reads { background: linear-gradient(135deg, #d4a574, #c9944d); }
    .platform-badge.foundry { background: linear-gradient(135deg, #2c3e50, #4a627a); }

    /* ----- typography ----- */
    h2 {
      font-size: 1.9rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: #1d1a2b;
      margin: 0.2rem 0 0.2rem;
    }
    .subtitle {
      color: #6b677a;
      font-size: 0.95rem;
      margin-bottom: 2rem;
      font-weight: 400;
      border-left: 3px solid #4b2aad;
      padding-left: 0.8rem;
      background: rgba(75, 42, 173, 0.02);
      border-radius: 0 4px 4px 0;
    }

    /* ----- form elements ----- */
    form label {
      display: block;
      font-size: 0.85rem;
      font-weight: 600;
      color: #2b263b;
      margin: 1.4rem 0 0.35rem;
      letter-spacing: 0.2px;
    }
    label:first-of-type { margin-top: 0; }

    input[type="text"],
    input[type="email"],
    input[type="password"] {
      width: 100%;
      padding: 0.9rem 1rem;
      border: 1.5px solid #e4e0ed;
      border-radius: 18px;
      font-size: 0.95rem;
      background: rgba(255,255,255,0.5);
      backdrop-filter: blur(4px);
      transition: 0.2s;
      font-family: 'Inter', sans-serif;
      color: #1d1a2b;
      outline: none;
    }
    input:focus {
      border-color: #4b2aad;
      box-shadow: 0 0 0 4px rgba(75, 42, 173, 0.08);
      background: white;
    }
    input::placeholder {
      color: #b2adc4;
      font-weight: 400;
    }

    .password-wrapper {
      position: relative;
      width: 100%;
    }
    .password-eye {
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      cursor: pointer;
      font-size: 1.1rem;
      user-select: none;
      color: #9a94af;
      padding: 4px 6px;
      border-radius: 30px;
      transition: 0.15s;
      line-height: 1;
    }
    .password-eye:hover { background: rgba(75, 42, 173, 0.06); color: #4b2aad; }
    .password-eye.showing { color: #4b2aad; background: rgba(75, 42, 173, 0.08); }

    /* ----- button & status ----- */
    .btn-primary {
      width: 100%;
      padding: 0.95rem;
      margin-top: 1.8rem;
      border: none;
      border-radius: 40px;
      background: #4b2aad;
      color: white;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: 0.2s;
      box-shadow: 0 8px 18px rgba(75, 42, 173, 0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-family: 'Inter', sans-serif;
    }
    .btn-primary:hover:not(:disabled) {
      background: #3a1f85;
      transform: scale(1.01);
      box-shadow: 0 10px 24px rgba(75, 42, 173, 0.25);
    }
    .btn-primary:disabled {
      opacity: 0.7;
      cursor: not-allowed;
      box-shadow: none;
    }

    .status {
      margin-top: 1.2rem;
      padding: 0.8rem 1rem;
      border-radius: 20px;
      font-size: 0.9rem;
      display: none;
      font-weight: 500;
      background: #f5f3fa;
      border: 1px solid transparent;
    }
    .status.show { display: block; }
    .status.success {
      background: #eaf6ed;
      color: #1f6b44;
      border-color: #b7dfc9;
    }
    .status.error {
      background: #fdeded;
      color: #b33c3c;
      border-color: #f5d0d0;
    }
    .status.info {
      background: #e8edfd;
      color: #2a4a9e;
      border-color: #c8d4f5;
    }

    /* ----- account & links ----- */
    .account-check {
      background: rgba(245, 242, 252, 0.5);
      backdrop-filter: blur(4px);
      padding: 1rem 1rem;
      border-radius: 30px;
      margin-top: 1.8rem;
      text-align: center;
      font-size: 0.9rem;
      border: 1px solid rgba(75, 42, 173, 0.04);
    }
    .account-check a {
      color: #4b2aad;
      font-weight: 600;
      text-decoration: none;
      border-bottom: 1.5px dotted transparent;
      transition: 0.1s;
    }
    .account-check a:hover { border-bottom-color: #4b2aad; }

    .links {
      text-align: center;
      margin-top: 1.2rem;
    }
    .links a {
      color: #6b677a;
      font-size: 0.85rem;
      text-decoration: none;
      font-weight: 500;
      transition: 0.15s;
      border-bottom: 1px solid transparent;
    }
    .links a:hover { color: #4b2aad; border-bottom-color: #4b2aad; }

    .divider {
      text-align: center;
      margin: 1.2rem 0 0.4rem;
      color: #bfbad0;
      font-size: 0.8rem;
      letter-spacing: 0.3px;
    }

    /* spinner */
    .loading-spinner { display: none; }
    .spinner {
      border: 2.5px solid rgba(255,255,255,0.2);
      border-top: 2.5px solid white;
      border-radius: 50%;
      width: 20px;
      height: 20px;
      animation: spin 0.8s linear infinite;
      display: inline-block;
    }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

    /* responsive */
    @media (max-width: 500px) {
      .container { padding: 1.8rem 1.4rem; border-radius: 28px; }
      h2 { font-size: 1.6rem; }
      .platform-badge { font-size: 0.65rem; padding: 0.3rem 1rem; }
    }
  </style>
</head>
<body>
<div class="container">

  <!-- back link - hidden via CSS -->
  <a href="#" id="backLink" class="back-link"><i class="fas fa-arrow-left"></i> Back</a>

  <!-- dynamic platform badge -->
  <div class="platform-badge" id="platformBadge">Volant Platform</div>

  <!-- breadcrumb - hidden via CSS -->
  <div class="breadcrumb" id="breadcrumb">
    <a href="#" id="breadcrumbHome">Home</a>
    <span>›</span>
    <span>Sign In</span>
  </div>

  <h2>Welcome back</h2>
  <p class="subtitle">Sign in to your account</p>

  <form id="login-form" class="auth-form">
    <input type="hidden" name="returnUrl" id="returnUrl" value="">
    
    <label for="login-email">Email or username</label>
    <input type="text" id="login-email" placeholder="you@example.com or username" autocomplete="email">

    <label for="login-password">Password</label>
    <div class="password-wrapper">
      <input type="password" id="login-password" placeholder="Enter password" autocomplete="current-password">
      <span id="toggle-password" class="password-eye"><i class="far fa-eye"></i></span>
    </div>

    <button type="submit" class="btn-primary" id="login-button">
      <span class="loading-spinner" id="spinner"><span class="spinner"></span></span>
      <span id="buttonText">Sign In</span>
    </button>
  </form>

  <div id="login-status" class="status"></div>

  <div class="account-check">
    <span>Don't have an account? </span>
    <a href="#" id="goToSignup">Sign up</a>
  </div>

  <div class="links">
    <a href="#" id="forgotPasswordLink">Forgot password?</a>
  </div>

  <div class="divider">secure · encrypted</div>
</div>

<script type="module">
  // ----- Firebase imports -----
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
  import {
    getAuth,
    signInWithEmailAndPassword,
    signOut,
    onAuthStateChanged
  } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-auth.js";
  import {
    getFirestore,
    doc,
    getDoc,
    collection,
    query,
    where,
    getDocs
  } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";

  // Firebase Config
  const firebaseConfig = {
    apiKey: "AIzaSyC4DHI8aBVY4JjTvJ-r-TGIDPsewtEWxzU",
    authDomain: "silent-depth.firebaseapp.com",
    projectId: "silent-depth",
    storageBucket: "silent-depth.firebasestorage.app",
    messagingSenderId: "78008755450",
    appId: "1:78008755450:web:3fd0f0f298a08820935543",
    measurementId: "G-WSWDCB7KD8"
  };
  const app = initializeApp(firebaseConfig);
  const auth = getAuth(app);
  const db = getFirestore(app);

  // ----- PLATFORM DETECTION -----
  const urlParams = new URLSearchParams(window.location.search);
  const platform = urlParams.get('platform') || 'poetry';
  const redirectUrl = urlParams.get('redirect');

  const platformConfig = {
    poetry: { name: 'Volant Poetry', badge: 'poetry', homeUrl: '../index.html', color: '#4b2aad' },
    reads: { name: 'Volant Reads', badge: 'reads', homeUrl: '../store/index.html', color: '#d4a574' },
    foundry: { name: 'Volant Foundry', badge: 'foundry', homeUrl: '../volant_foundry/volant_foundry/index.html', color: '#2c3e50' }
  };
  const currentPlatform = platformConfig[platform] || platformConfig.poetry;

  // update UI
  document.getElementById('platformBadge').textContent = currentPlatform.name;
  document.getElementById('platformBadge').classList.add(currentPlatform.badge);

  // DOM refs
  const loginForm = document.getElementById('login-form');
  const loginButton = document.getElementById('login-button');
  const statusEl = document.getElementById('login-status');
  const passwordInput = document.getElementById("login-password");
  const togglePassword = document.getElementById("toggle-password");
  const goToSignup = document.getElementById('goToSignup');
  const forgotPasswordLink = document.getElementById('forgotPasswordLink');
  const spinner = document.getElementById('spinner');
  const buttonText = document.getElementById('buttonText');
  const loginEmail = document.getElementById('login-email');

  // ----- password toggle -----
  togglePassword.addEventListener("click", () => {
    const isPassword = passwordInput.type === "password";
    passwordInput.type = isPassword ? "text" : "password";
    togglePassword.classList.toggle("showing", isPassword);
    togglePassword.innerHTML = isPassword ? '<i class="fas fa-eye-slash"></i>' : '<i class="far fa-eye"></i>';
  });

  // ----- navigation -----
  goToSignup.addEventListener('click', (e) => {
    e.preventDefault();
    const params = new URLSearchParams();
    params.append('platform', platform);
    if (redirectUrl) params.append('redirect', redirectUrl);
    window.location.href = `universal-signup.html?${params.toString()}`;
  });
  forgotPasswordLink.addEventListener('click', (e) => {
    e.preventDefault();
    const params = new URLSearchParams();
    params.append('platform', platform);
    if (redirectUrl) params.append('redirect', redirectUrl);
    window.location.href = `users-reset.html?${params.toString()}`;
  });

  // ----- status helper -----
  function showStatus(message, type = 'error') {
    statusEl.textContent = message;
    statusEl.className = `status show ${type}`;
  }

  // ============================================================
  // ====== SMART RETURN URL HANDLER ======
  // ============================================================
  
  function getSmartReturnUrl() {
    // 1. Check URL parameters first
    const urlParams = new URLSearchParams(window.location.search);
    let returnUrl = urlParams.get('returnUrl');
    
    // 2. Check session storage
    if (!returnUrl) {
      returnUrl = sessionStorage.getItem('returnUrl');
    }
    
    // 3. Check localStorage (as fallback)
    if (!returnUrl) {
      returnUrl = localStorage.getItem('returnUrl');
    }
    
    // 4. Check referrer (the page that sent us here)
    if (!returnUrl || returnUrl === 'null' || returnUrl === 'undefined') {
      returnUrl = document.referrer;
    }
    
    // 5. If still nothing, use the stored redirect from login link click
    if (!returnUrl || returnUrl === 'null' || returnUrl === 'undefined') {
      returnUrl = sessionStorage.getItem('preLoginPage');
    }
    
    // Clean up and validate
    if (returnUrl && returnUrl !== 'null' && returnUrl !== 'undefined') {
      // Decode if encoded
      try {
        returnUrl = decodeURIComponent(returnUrl);
      } catch (e) {
        // Already decoded or not encoded
      }
      
      // IMPORTANT: Keep query parameters! Don't strip them!
      // Only remove the returnUrl parameter itself to avoid loops
      try {
        const url = new URL(returnUrl, window.location.origin);
        url.searchParams.delete('returnUrl');
        returnUrl = url.pathname + url.search + url.hash;
      } catch (e) {
        // If URL parsing fails, just use as-is but remove any returnUrl param
        returnUrl = returnUrl.replace(/[?&]returnUrl=[^&]*/, '').replace(/&+$/, '');
      }
      
      // Don't redirect to auth pages
      const excludePages = ['login', 'signup', 'verify', 'reset', 'check-verification'];
      if (excludePages.some(page => returnUrl.includes(page))) {
        returnUrl = null;
      }
      
      // Make sure it's not empty
      if (returnUrl === '' || returnUrl === '/' || returnUrl === 'null' || returnUrl === 'undefined') {
        returnUrl = null;
      }
    }
    
    // If no valid return URL, use platform home
    return returnUrl || currentPlatform.homeUrl;
  }

  // ============================================================
  // ====== LOGIN WITH SMART REDIRECT ======
  // ============================================================
  
  loginForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    const loginInput = loginEmail.value.trim();
    const password = passwordInput.value;

    loginButton.disabled = true;
    spinner.style.display = 'inline';
    buttonText.textContent = 'Signing in…';

    try {
      let emailToUse = loginInput;
      if (!loginInput.includes("@")) {
        const q = query(collection(db, "users"), where("username", "==", loginInput));
        const querySnap = await getDocs(q);
        if (querySnap.empty) {
          showStatus("❌ Username or email not found");
          loginButton.disabled = false;
          spinner.style.display = 'none';
          buttonText.textContent = 'Sign In';
          return;
        }
        emailToUse = querySnap.docs[0].data().email;
      }

      const userCred = await signInWithEmailAndPassword(auth, emailToUse, password);
      const user = userCred.user;

      showStatus("⏳ Verifying email…", 'info');

      for (let i = 0; i < 3; i++) {
        await user.reload();
        if (user.emailVerified) break;
        await new Promise(resolve => setTimeout(resolve, 500));
      }

      if (!user.emailVerified) {
        await signOut(auth);
        localStorage.setItem('pendingVerificationEmail', user.email);
        const params = new URLSearchParams();
        params.append('email', user.email);
        params.append('platform', platform);
        if (redirectUrl) params.append('redirect', redirectUrl);
        setTimeout(() => {
          window.location.href = `verify-email.html?${params.toString()}`;
        }, 1200);
        return;
      }

      showStatus("✅ Login successful! Redirecting…", 'success');

      // ========================================
      // Use SMART return URL
      // ========================================
      
      let finalRedirect = getSmartReturnUrl();
      
      // If redirectUrl parameter exists and no returnUrl found, use it
      if (redirectUrl && finalRedirect === currentPlatform.homeUrl) {
        try {
          const decodedRedirect = decodeURIComponent(redirectUrl);
          if (!decodedRedirect.includes('universal-login') &&
              !decodedRedirect.includes('universal-signup') &&
              !decodedRedirect.includes('users-login') &&
              !decodedRedirect.includes('users-signup') &&
              !decodedRedirect.includes('users-reset') &&
              !decodedRedirect.includes('verify-email')) {
            finalRedirect = decodedRedirect;
          }
        } catch (e) {
          // Use default if decoding fails
        }
      }
      
      // Clean up storage
      sessionStorage.removeItem('returnUrl');
      sessionStorage.removeItem('preLoginPage');
      localStorage.removeItem('returnUrl');
      
      console.log('🔄 Redirecting to:', finalRedirect);

      setTimeout(() => {
        window.location.href = finalRedirect;
      }, 1200);

    } catch (err) {
      console.error("Login error:", err);
      let errorMsg = "❌ " + err.message;
      if (err.code === 'auth/user-not-found') errorMsg = "❌ Username or email not found";
      else if (err.code === 'auth/wrong-password') errorMsg = "❌ Incorrect password";
      else if (err.code === 'auth/too-many-requests') errorMsg = "❌ Too many failed attempts. Try again later.";
      showStatus(errorMsg);
      loginButton.disabled = false;
      spinner.style.display = 'none';
      buttonText.textContent = 'Sign In';
    }
  });

  // ----- auth state -----
  onAuthStateChanged(auth, (user) => {
    if (user && user.emailVerified) {
      // Only redirect if we're not already redirecting
      if (!window._redirecting) {
        window._redirecting = true;
        let returnUrl = getSmartReturnUrl();
        
        // Clean up
        sessionStorage.removeItem('returnUrl');
        sessionStorage.removeItem('preLoginPage');
        localStorage.removeItem('returnUrl');
        
        window.location.href = returnUrl;
      }
    }
  });

  // ============================================================
  // ====== STORE CURRENT PAGE BEFORE NAVIGATING TO LOGIN ======
  // ============================================================
  
  // When clicking ANY login/signup link, store the current page
  document.addEventListener('click', function(e) {
    const link = e.target.closest('a');
    if (link) {
      const href = link.getAttribute('href');
      if (href && (href.includes('login') || href.includes('signup') || href.includes('verify'))) {
        // Get the current page URL
        const currentPage = window.location.pathname + window.location.search + window.location.hash;
        
        // Store it in multiple places for reliability
        sessionStorage.setItem('preLoginPage', currentPage);
        sessionStorage.setItem('returnUrl', currentPage);
        localStorage.setItem('returnUrl', currentPage);
        
        console.log('📌 Stored pre-login page:', currentPage);
      }
    }
  });

  // ============================================================
  // ====== RESTORE RETURN URL FROM SESSION ON PAGE LOAD ======
  // ============================================================
  
  // When the login page loads, check if we have a stored return URL
  (function restoreReturnUrl() {
    // Check if we came from a redirect with a returnUrl parameter
    const urlParams = new URLSearchParams(window.location.search);
    let returnUrl = urlParams.get('returnUrl');
    
    if (returnUrl) {
      // Decode it
      try {
        returnUrl = decodeURIComponent(returnUrl);
      } catch (e) {}
      
      // Store it
      sessionStorage.setItem('returnUrl', returnUrl);
      sessionStorage.setItem('preLoginPage', returnUrl);
      localStorage.setItem('returnUrl', returnUrl);
      
      // Set the hidden input value
      const hiddenInput = document.getElementById('returnUrl');
      if (hiddenInput) {
        hiddenInput.value = returnUrl;
      }
      
      console.log('📌 Restored return URL from query param:', returnUrl);
    } else {
      // Check if we have a stored return URL from a previous click
      const storedUrl = sessionStorage.getItem('preLoginPage') || sessionStorage.getItem('returnUrl');
      if (storedUrl && !storedUrl.includes('login') && !storedUrl.includes('signup')) {
        const hiddenInput = document.getElementById('returnUrl');
        if (hiddenInput) {
          hiddenInput.value = storedUrl;
        }
        console.log('📌 Restored return URL from storage:', storedUrl);
      }
    }
  })();

</script>

<script>
// Return URL Handler - Redirect to previous page after login
(function() {
    // Function to get return URL
    function getReturnUrl() {
        // Check URL parameters first
        const urlParams = new URLSearchParams(window.location.search);
        let returnUrl = urlParams.get('returnUrl');
        
        // Check session storage
        if (!returnUrl) {
            returnUrl = sessionStorage.getItem('returnUrl');
        }
        
        // Check preLoginPage
        if (!returnUrl) {
            returnUrl = sessionStorage.getItem('preLoginPage');
        }
        
        // Check referrer
        if (!returnUrl || returnUrl === 'null' || returnUrl === 'undefined') {
            returnUrl = document.referrer || window.location.pathname;
        }
        
        // Exclude auth pages
        const excludePages = ['login', 'signup', 'verify', 'reset', 'check-verification'];
        if (excludePages.some(page => returnUrl.includes(page))) {
            returnUrl = null;
        }
        
        // Clean up URL - PRESERVE query parameters
        if (returnUrl && returnUrl !== 'null' && returnUrl !== 'undefined') {
            // Remove any returnUrl parameter to avoid loops
            try {
                const url = new URL(returnUrl, window.location.origin);
                url.searchParams.delete('returnUrl');
                returnUrl = url.pathname + url.search + url.hash;
            } catch (e) {
                // If URL parsing fails, use regex to remove returnUrl param
                returnUrl = returnUrl.replace(/[?&]returnUrl=[^&]*/, '').replace(/&+$/, '');
            }
            
            // Make sure it starts with /
            if (!returnUrl.startsWith('/') && !returnUrl.startsWith('http')) {
                returnUrl = '/' + returnUrl;
            }
        }
        
        // If we have a platform-specific home URL, use it as fallback
        const platform = urlParams.get('platform') || 'poetry';
        const platformConfig = {
            poetry: { homeUrl: '/index.html' },
            reads: { homeUrl: '/store/index.html' },
            foundry: { homeUrl: '/volant_foundry/index.html' }
        };
        const defaultHome = platformConfig[platform]?.homeUrl || '/index.html';
        
        return returnUrl || defaultHome;
    }
    
    // Function to redirect after successful login
    window.redirectAfterLogin = function() {
        const returnUrl = getReturnUrl();
        sessionStorage.removeItem('returnUrl');
        sessionStorage.removeItem('preLoginPage');
        localStorage.removeItem('returnUrl');
        window.location.href = returnUrl;
    };
    
    // Save return URL when page loads (for login page)
    if (window.location.pathname.includes('login') || 
        window.location.pathname.includes('signup')) {
        const returnUrl = getReturnUrl();
        if (returnUrl && !returnUrl.includes('login') && !returnUrl.includes('signup')) {
            sessionStorage.setItem('returnUrl', returnUrl);
            sessionStorage.setItem('preLoginPage', returnUrl);
        }
        
        // Update any login form action to include returnUrl
        document.addEventListener('DOMContentLoaded', function() {
            const forms = document.querySelectorAll('form');
            forms.forEach(form => {
                if (form.action && form.action.includes('login')) {
                    const hiddenInput = document.createElement('input');
                    hiddenInput.type = 'hidden';
                    hiddenInput.name = 'returnUrl';
                    hiddenInput.value = returnUrl || '/index.html';
                    form.appendChild(hiddenInput);
                }
            });
            
            // Set the hidden input value
            const hiddenInput = document.getElementById('returnUrl');
            if (hiddenInput && returnUrl) {
                hiddenInput.value = returnUrl;
            }
        });
    }
    
    // Store current page before navigating to login
    document.addEventListener('click', function(e) {
        const link = e.target.closest('a');
        if (link) {
            const href = link.getAttribute('href');
            if (href && (href.includes('login') || href.includes('signup') || href.includes('verify'))) {
                // Store current page before leaving
                const currentPath = window.location.pathname + window.location.search + window.location.hash;
                if (!currentPath.includes('login') && !currentPath.includes('signup') && !currentPath.includes('verify')) {
                    sessionStorage.setItem('returnUrl', currentPath);
                    sessionStorage.setItem('preLoginPage', currentPath);
                    localStorage.setItem('returnUrl', currentPath);
                    console.log('📌 Stored return URL from click:', currentPath);
                }
            }
        }
    });
    
    // Also intercept form submissions
    document.addEventListener('submit', function(e) {
        const form = e.target;
        if (form && form.action && (form.action.includes('login') || form.action.includes('signup'))) {
            // Store the current page before submitting the form
            const currentPath = window.location.pathname + window.location.search + window.location.hash;
            if (!currentPath.includes('login') && !currentPath.includes('signup')) {
                sessionStorage.setItem('returnUrl', currentPath);
                sessionStorage.setItem('preLoginPage', currentPath);
                localStorage.setItem('returnUrl', currentPath);
            }
            
            // Add returnUrl to form if not present
            let returnInput = form.querySelector('input[name="returnUrl"]');
            if (!returnInput) {
                returnInput = document.createElement('input');
                returnInput.type = 'hidden';
                returnInput.name = 'returnUrl';
                form.appendChild(returnInput);
            }
            const storedUrl = sessionStorage.getItem('returnUrl') || sessionStorage.getItem('preLoginPage');
            returnInput.value = storedUrl || '/index.html';
        }
    });
    
    console.log('✅ Smart Return URL Handler initialized');
})();
</script>
